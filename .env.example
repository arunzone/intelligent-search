# OpenAI (primary LLM — leave unset to use Ollama only)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local LLM / fallback)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Part 1 — company search API
COMPANY_SEARCH_URL=http://host.docker.internal:8000
COMPANY_SEARCH_TIMEOUT=10.0

# Service
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
